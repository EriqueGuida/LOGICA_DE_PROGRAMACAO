programa
{
    funcao inicio()
    {
        inteiro a, b, soma
        escreva("Digite A: ")
        leia(a)
        escreva("Digite B: ")
        leia(b)

        // soma = a * b - Código errado
        soma = a + b // O operador utilizado anteriormente estava errado

        escreva("Soma = ", soma)
    }
}