programa
{
    funcao inicio()
    {
        real n1, n2, media

        escreva("Digite n1: ") // Adicionado para melhorar usabilidade
        leia(n1)
        escreva("Digite n2: ") // Adicionado para melhorar usabilidade
        leia(n2)

        // media = (n1 + n2) / 3 
        media = (n1 + n2) / 2 // O certo seria dividir por 2


        escreva("Média: ", media)
    }
}