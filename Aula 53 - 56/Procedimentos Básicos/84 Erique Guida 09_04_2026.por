programa {
  funcao inicio() {
    verificarNumeros()
  }

  funcao verificarNumeros() {
    inteiro n 
    
    faca
    {
      escreva("Digite um número: ")
      leia(n)

      se(n > 0)
      {
        escreva("Número Positivo. \n")
      }
      senao se(n < 0)
      {
        escreva("Número Negativo. \n")
      }
    } 
    enquanto(n != 0)
  }
}
