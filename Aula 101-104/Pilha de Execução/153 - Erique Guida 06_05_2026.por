programa {
  funcao inicio() {
    escreva("Inicio\n")
    procedimentoA()
  }

  funcao procedimentoA(){
    escreva("A1\n")
    procedimentoB()
    escreva("A2\n")
  }

  funcao procedimentoB(){
    escreva("B1\n")
    procedimentoC()
    escreva("B2\n")
  }

  funcao procedimentoC(){
    escreva("C\n")
  }
}
